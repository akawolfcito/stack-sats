{
  "manifest_version": 3,
  "name": "DenVault",
  "short_name": "DenVault",
  "version": "1.0.1",
  "description": "DenVault - Your Bitcoin Layer 2 wallet for the Stacks ecosystem.",
  "action": {
    "default_title": "DenVault",
    "default_popup": "index.html"
  },
  "permissions": ["storage", "tabs", "sidePanel", "clipboardRead"],
  "side_panel": {
    "default_path": "index.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'none'; base-uri 'none'; form-action 'none'; frame-ancestors 'none';"
  },
  "host_permissions": [
    "https://api.hiro.so/*",
    "https://api.testnet.hiro.so/*",
    "https://api.platform.hiro.so/*"
  ],
  "icons": {
    "16": "denvault-16.png",
    "32": "denvault-32.png",
    "48": "denvault-48.png",
    "128": "denvault-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injection.js"],
      "matches": ["https://*/*"]
    }
  ]
}
