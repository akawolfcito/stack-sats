{
  "manifest_version": 3,
  "name": "DenVault",
  "version": "1.0.0",
  "description": "DenVault - Your Bitcoin Layer 2 wallet for the Stacks ecosystem.",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": ["scripting", "tabs", "activeTab", "storage", "sidePanel"],
  "side_panel": {
    "default_path": "index.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'none'; base-uri 'none'; form-action 'none'; frame-ancestors 'none';"
  },
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*",
    "https://api.platform.hiro.so/*",
    "https://api.hiro.so/*",
    "https://stacks-node-api.testnet.stacks.co/*",
    "https://stacks-node-api.mainnet.stacks.co/*"
  ],
  "icons": {
    "16": "denvault-16.png",
    "32": "denvault-32.png",
    "48": "denvault-48.png",
    "128": "denvault-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injection.js"],
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://*/*"
      ]
    }
  ]
}
