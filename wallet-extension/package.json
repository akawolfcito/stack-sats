{
  "name": "wallet-extension",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "ui:snapshots": "VITE_UI_SNAPSHOT=1 playwright test golden-screenshots --project=chromium",
    "ui:shots": "VITE_UI_SNAPSHOT=1 playwright test golden-matrix --project=chromium",
    "ui:verify": "bash scripts/ui-verify-snapshots.sh",
    "ui:accept": "bash scripts/ui-accept.sh",
    "ui:diff": "bash scripts/ui-diff-snapshots.sh",
    "ui:guard": "bash scripts/ui-commit-guard.sh",
    "audit:accent": "bash scripts/audit-accent.sh",
    "audit:ui": "bash scripts/audit-ui.sh"
  },
  "dependencies": {
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "@stacks/connect": "^8.1.7",
    "@stacks/encryption": "7",
    "@stacks/network": "7",
    "@stacks/transactions": "^7.0.4",
    "@stacks/wallet-sdk": "^7.0.4",
    "bitcoinjs-lib": "^6.1.7",
    "browserify": "^17.0.1",
    "buffer": "^6.0.3",
    "c32check": "^2.0.0",
    "chrome-types": "^0.1.340",
    "lucide-vue-next": "^0.483.0",
    "qrcode": "^1.5.4",
    "tiny-secp256k1": "^2.2.3",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tsconfig/node22": "^22.0.0",
    "@types/chrome": "^0.0.304",
    "@types/node": "^22.19.3",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-typescript": "^14.3.0",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.18.0",
    "eslint-plugin-vue": "^9.32.0",
    "jiti": "^2.4.2",
    "jsdom": "^27.4.0",
    "npm-run-all2": "^7.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.7.3",
    "vite": "^6.0.11",
    "vite-plugin-vue-devtools": "^7.7.1",
    "vite-plugin-wasm": "^3.4.1",
    "vitest": "^4.0.16",
    "vue-tsc": "^2.2.0",
    "@playwright/test": "^1.50.0"
  }
}
