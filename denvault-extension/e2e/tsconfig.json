{
  "extends": "@tsconfig/node22/tsconfig.json",
  "include": ["**/*.ts", "../scripts/**/*.ts"],
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "lib": ["ES2022", "DOM"],
    "allowJs": true
  }
}
